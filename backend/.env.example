# Copie este arquivo para .env e preencha os valores

# ── Backend ──────────────────────────────────────────────────────────────────
APP_NAME="Cifras AI Backend"
MODEL_VERSION="0.1.0"
MAX_AUDIO_DURATION_S=600
UPLOAD_DIR=/tmp/cifras_uploads

# ── Demucs ───────────────────────────────────────────────────────────────────
# Modelos disponíveis: htdemucs, htdemucs_ft, htdemucs_6s, mdx_extra
DEMUCS_MODEL=htdemucs
# Usar "cuda" se houver GPU disponível — reduz tempo de 5–10x
DEMUCS_DEVICE=cpu
DEMUCS_JOBS=1

# ── Chord Recognizer ─────────────────────────────────────────────────────────
# "chroma" → fallback sem modelo externo (Fase 0)
# "btc"    → modelo BTC (requer CHORD_MODEL_PATH)
CHORD_BACKEND=chroma
CHORD_MODEL_PATH=

# ── Supabase (Fase 2) ─────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Letras (backlog 9.1) ──────────────────────────────────────────────────────
# Opt-in: risco de copyright maior que acordes/BPM/tom (ver plano 7.1/9.1).
# Nunca persistido no cache, mesmo com LYRICS_ENABLED=true.
LYRICS_ENABLED=false
LYRICS_MODEL_SIZE=base
