{
  "manifest_version": 3,
  "name": "Cifras AI",
  "version": "0.1.0",
  "description": "Reconhece acordes, BPM e tonalidade de vídeos do YouTube em tempo real.",

  "permissions": [
    "tabCapture",
    "offscreen",
    "sidePanel",
    "activeTab",
    "tabs"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "action": {
    "default_title": "Cifras AI",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
